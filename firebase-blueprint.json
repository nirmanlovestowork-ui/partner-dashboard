{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task in the dashboard",
      "type": "object",
      "properties": {
        "task_name": { "type": "string" },
        "description": { "type": "string" },
        "due_date": { "type": "string", "format": "date-time" },
        "status": { "type": "boolean" },
        "assignee": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Party": {
      "title": "Party",
      "type": "object",
      "properties": {}
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "properties": {}
    },
    "Counter": {
      "title": "Counter",
      "type": "object",
      "properties": {}
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {}
    }
  },
  "firestore": {
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" }
    },
    "/parties/{partyId}": {
      "schema": { "$ref": "#/entities/Party" }
    },
    "/services/{serviceId}": {
      "schema": { "$ref": "#/entities/Service" }
    },
    "/counters/{counterId}": {
      "schema": { "$ref": "#/entities/Counter" }
    },
    "/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/Invoice" }
    }
  }
}
