rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{taskId} {
      allow read, write: if true;
    }
    match /counters/{counterId} {
      allow read, write: if true;
    }
    match /parties/{partyId} {
      allow read, write: if true;
    }
    match /services/{serviceId} {
      allow read, write: if true;
    }
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
  }
}
